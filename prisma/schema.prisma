// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * General
 */

model Language {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  flagEmoji String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usersNative      User[]            @relation("UserNativeLanguage")
  usersCurrent     User[]            @relation("UserCurrentLanguage")
  userLanguages    UserLanguage[]
  wordCategories   WordCategory[]
  words            Word[]
  chats            Chat[]
  scenarios        Scenario[]
  scenarioSessions ScenarioSession[]
}

/**
 * Auth
 */

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

/**
 * User
 */

model User {
  id               String         @id
  name             String
  email            String
  emailVerified    Boolean        @default(false)
  image            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @default(now()) @updatedAt
  sessions         Session[]
  accounts         Account[]
  words            Word[]
  wordCategories   WordCategory[]
  grammar          Grammar[]
  chats            Chat[]
  scenarioSessions ScenarioSession[]
  languages        UserLanguage[]
  scenarios        Scenario[]
  nativeLanguageId String
  nativeLanguage   Language       @relation("UserNativeLanguage", fields: [nativeLanguageId], references: [id])

  currentLanguageId String
  currentLanguage   Language @relation("UserCurrentLanguage", fields: [currentLanguageId], references: [id])

  @@unique([email])
  @@map("user")
}

model UserLanguage {
  id         String @id @default(cuid())
  userId     String
  languageId String

  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  stats      UserLanguageStats?
  activities UserLanguageActivity[]
  words      Word[]
  language   Language               @relation(fields: [languageId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([userId, languageId])
}

model UserLanguageStats {
  id              String   @id @default(cuid())
  streakStartedAt DateTime
  lastActivityAt  DateTime
  xp              Int      @default(0)
  level           Int      @default(1)

  userLanguageId String       @unique
  userLanguage   UserLanguage @relation(fields: [userLanguageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserLanguageActivity {
  id             String   @id @default(cuid())
  type           String
  timestamp      DateTime @default(now())
  userLanguageId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userLanguage UserLanguage @relation(fields: [userLanguageId], references: [id], onDelete: Cascade)
}

/**
 * Vocabulary
 */

model Word {
  id            String   @id @default(cuid())
  primary       String
  primaryInfo   String?
  secondary     String
  secondaryInfo String?
  wordType      String?
  forms         Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  language      Language @relation(fields: [languageId], references: [id])
  examples      String[] @default([])

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoryId String?
  category   WordCategory? @relation(fields: [categoryId], references: [id])

  progress       WordProgress?
  userLanguage   UserLanguage? @relation(fields: [userLanguageId], references: [id])
  userLanguageId String?
  languageId     String
}

model WordCategory {
  id       String   @id @default(cuid())
  name     String
  language Language @relation(fields: [languageId], references: [id])

  parentId String?
  parent   WordCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children WordCategory[] @relation("CategoryHierarchy")

  words Word[]

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  languageId String
}

model WordProgress {
  id             String    @id @default(cuid())
  wordId         String    @unique
  level          Int       @default(0)
  intervalDays   Int       @default(0)
  nextReviewAt   DateTime?
  lastReviewedAt DateTime?
  repititions    Int       @default(0)
  totalCorrect   Int       @default(0)
  totalIncorrect Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  word Word @relation(fields: [wordId], references: [id], onDelete: Cascade)
}

/**
 * Grammar
 */

model Grammar {
  id        String   @id @default(cuid())
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/**
 * Chat
 */

model Chat {
  id             String   @id @default(cuid())
  title          String?
  messages       Json     @default("[]")
  assistantName  String   @default("Assistant")
  assistantIcon  String?
  activeStreamId String?
  language       Language @relation(fields: [languageId], references: [id])

  scenarioId    String?
  scenario      Scenario? @relation(fields: [scenarioId], references: [id])
  targetsStatus Boolean[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId     String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  languageId String

  @@index([userId])
  @@map("chat")
}

model Scenario {
  id                    String   @id @default(cuid())
  title                 String
  description           String
  language              Language @relation(fields: [languageId], references: [id])
  image                 String
  assistantName         String   @default("Assistant")
  assistantInstructions String
  firstAssistantMessage String
  targets               String[]
  level                 String?
  tags                  String[] @default([])
  isUserCreated         Boolean  @default(false)
  isAiGenerated         Boolean  @default(false)
  generatedAt           DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @default(now()) @updatedAt

  chats    Chat[]
  sessions ScenarioSession[]
  languageId String

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScenarioSession {
  id             String   @id @default(cuid())
  title          String?
  messages       Json     @default("[]")
  assistantName  String   @default("Assistant")
  assistantIcon  String?
  activeStreamId String?
  targetsStatus  Boolean[] @default([])

  scenario   Scenario @relation(fields: [scenarioId], references: [id])
  scenarioId String

  language   Language @relation(fields: [languageId], references: [id])
  languageId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([scenarioId])
  @@map("scenario_session")
}
