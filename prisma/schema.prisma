// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * Enums
 */

enum Language {
  GERMAN
  SERBIAN
  ENGLISH
  HUNGARIAN
}

enum ActivityType {
  VOCABULARY_ADDED
  VOCABULARY_MASTERED
  NEW_VOCABULARY_LEARNED
  PRACTICE_COMPLETED
  CHAT_INITIATED
  SCENARIO_STARTED
  SCENARIO_COMPLETED
  GRAMMAR_ADDED
  LEVEL_UP
  WORD_CATEGORY_CREATED
}

/**
 * Auth
 */

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

/**
 * User
 */

model User {
  id             String         @id
  name           String
  email          String
  emailVerified  Boolean        @default(false)
  image          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @default(now()) @updatedAt
  sessions       Session[]
  accounts       Account[]
  words          Word[]
  wordCategories WordCategory[]
  grammar        Grammar[]
  chats          Chat[]
  languages      UserLanguage[]
  nativeLanguage Language

  @@unique([email])
  @@map("user")
}

model UserLanguage {
  id       String   @id @default(cuid())
  userId   String
  language Language
  statsId  String

  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  stats      UserLanguageStats      @relation(fields: [statsId], references: [id], onDelete: Cascade)
  activities UserLanguageActivity[]
  words      Word[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([userId, language])
}

model UserLanguageStats {
  id              String         @id
  streakStartedAt DateTime
  lastActivityAt  DateTime
  xp              Int            @default(0)
  level           Int            @default(1)
  userLanguages   UserLanguage[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @default(now()) @updatedAt
}

model UserLanguageActivity {
  id             String       @id
  type           ActivityType
  timestamp      DateTime     @default(now())
  userLanguageId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  userLanguage UserLanguage @relation(fields: [userLanguageId], references: [id], onDelete: Cascade)
}

/**
 * Vocabulary
 */

model Word {
  id            String   @id
  primary       String
  primaryInfo   String?
  secondary     String
  secondaryInfo String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  language      Language
  examples      String[] @default([])

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoryId String?
  category   WordCategory? @relation(fields: [categoryId], references: [id])

  progress       WordProgress?
  userLanguage   UserLanguage? @relation(fields: [userLanguageId], references: [id])
  userLanguageId String?
}

model WordCategory {
  id       String   @id
  name     String
  language Language

  parentId String?
  parent   WordCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children WordCategory[] @relation("CategoryHierarchy")

  words Word[]

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WordProgress {
  id             String    @id
  wordId         String    @unique
  level          Int       @default(0)
  intervalDays   Int       @default(0)
  nextReviewAt   DateTime?
  lastReviewedAt DateTime?
  repititions    Int       @default(0)
  totalCorrect   Int       @default(0)
  totalIncorrect Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  word Word @relation(fields: [wordId], references: [id], onDelete: Cascade)
}

/**
 * Grammar
 */

model Grammar {
  id        String   @id
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/**
 * Chat
 */

model Chat {
  id             String   @id
  title          String?
  messages       Json     @default("[]")
  assistantName  String   @default("Assistant")
  assistantIcon  String?
  activeStreamId String?
  language       Language

  scenarioId    String?
  scenario      Scenario? @relation(fields: [scenarioId], references: [id])
  targetsStatus Boolean[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("chat")
}

model Scenario {
  id                    String   @id
  title                 String
  description           String
  language              Language
  image                 String
  assistantName         String   @default("Assistant")
  assistantInstructions String
  firstAssistantMessage String
  targets               String[]
  createdAt             DateTime @default(now())
  updatedAt             DateTime @default(now()) @updatedAt

  chats Chat[]
}
